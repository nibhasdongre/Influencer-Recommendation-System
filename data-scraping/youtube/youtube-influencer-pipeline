        cursor.execute("SELECT * FROM Assets LIMIT 1")
        if cursor.fetchone():
            columns = [desc[0] for desc in cursor.description]
            null_counts = {}
            for col in columns:
                cursor.execute(f"SELECT COUNT(*) FROM Assets WHERE {col} IS NULL")
                null_counts[col] = cursor.fetchone()[0]
            stats['assets_nulls'] = null_counts
        
        return stats

    def run_pipeline(self):
        """Main pipeline execution"""
        logger.info("Starting YouTube Influencer Discovery Pipeline")
        
        # Step 1: Discover creators
        channel_ids = self.discover_creators()
        
        # Step 2: Populate database
        self.populate_database(channel_ids)
        
        # Step 3: Print statistics
        stats = self.get_stats()
        print("\n" + "="*60)
        print("DATABASE STATISTICS")
        print("="*60)
        print(f"Creators: {stats['creators_total']} total rows")
        if 'creators_nulls' in stats:
            print("Creators null counts:", {k: v for k, v in stats['creators_nulls'].items() if v > 0})
        
        print(f"Videos: {stats['videos_total']} total rows")
        if 'videos_nulls' in stats:
            print("Videos null counts:", {k: v for k, v in stats['videos_nulls'].items() if v > 0})
        
        print(f"Metrics: {stats['metrics_total']} total rows")
        if 'metrics_nulls' in stats:
            print("Metrics null counts:", {k: v for k, v in stats['metrics_nulls'].items() if v > 0})
        
        print(f"Assets: {stats['assets_total']} total rows")
        if 'assets_nulls' in stats:
            print("Assets null counts:", {k: v for k, v in stats['assets_nulls'].items() if v > 0})
        
        print("="*60)
        logger.info("Pipeline completed successfully")

    def close(self):
        """Cleanup"""
        self.conn.close()

